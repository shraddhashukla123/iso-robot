# Copy to backend/.env and/or keep secrets in repo-root .env (both are loaded if present;
# repo-root values override backend when the same key exists in both).

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Optional. Omit for deployment default (required for o-series / reasoning models that reject custom temperature).
# AZURE_OPENAI_TEMPERATURE=1
LOG_LEVEL=INFO

# Optional overrides (defaults: backend/data/db.sqlite and <repo>/all-docs)
# DATABASE_PATH=
# DOCUMENTS_DIR=

# When true (default), use local PDF text + heuristics if Azure Document Intelligence or OpenAI return errors.
USE_LLM_FALLBACK=true

# Controls extraction: one LLM call for the full PDF text when under this character limit (layout from Document Intelligence).
# CONTROL_EXTRACTION_MAX_CHARS_PER_CALL=100000
# If the PDF text is larger, it is split into chunks (still LLM per chunk, then deduped).
# CONTROL_EXTRACTION_CHUNK_CHARS=48000
# CONTROL_EXTRACTION_CHUNK_OVERLAP=1200
# Set true only if you want keyword heuristics when the LLM returns zero controls (usually leave false).
# CONTROL_EXTRACTION_HEURISTIC_ON_EMPTY=false
